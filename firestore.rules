rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Diagnostics connection checker path
    match /test/{docId} {
      allow read: if true;
    }

    // Validation Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'redhadadoua@gmail.com';
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || request.auth.token.email == 'redhadadoua@gmail.com');
      allow list: if isSignedIn() && (request.auth.token.email == 'redhadadoua@gmail.com');
      allow create, update: if isSignedIn() && (request.auth.uid == userId || request.auth.token.email == 'redhadadoua@gmail.com');
      allow delete: if isSignedIn() && (request.auth.token.email == 'redhadadoua@gmail.com');
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'name', 'category', 'price', 'image', 'color', 'stock']) &&
             data.id is number &&
             data.name is string && data.name.size() <= 200 &&
             data.category is string && data.category.size() <= 100 &&
             data.price is string && data.price.size() <= 50 &&
             data.image is string && data.image.size() <= 2000 &&
             data.color is string && data.color.size() <= 100 &&
             data.stock is number;
    }

    match /products/{productId} {
      allow read, list: if true;
      allow create, update, delete: if isAdmin() && isValidId(productId) && (request.method == 'delete' || isValidProduct(incoming()));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'items', 'total', 'status', 'createdAt', 'shippingInfo']) &&
             data.userId is string &&
             data.items is list && data.items.size() <= 50 &&
             data.total is number &&
             data.status is string &&
             data.shippingInfo is map &&
             (data.createdAt == request.time || data.createdAt is timestamp);
    }

    match /orders/{orderId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid) || resource.data.userId == 'guest';
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if (isAdmin() || incoming().userId == 'guest' || (isSignedIn() && incoming().userId == request.auth.uid)) && isValidId(orderId) && isValidOrder(incoming());
      allow update: if (isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid)) && isValidId(orderId) && isValidOrder(incoming());
      allow delete: if isAdmin();
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['storeName', 'currency', 'taxRate', 'theme']) &&
             data.storeName is string && data.storeName.size() <= 200 &&
             data.currency is string && data.currency.size() <= 10 &&
             data.taxRate is number &&
             data.theme is string && data.theme.size() <= 50;
    }

    match /settings/{settingsId} {
      allow get, list: if settingsId != 'google_sheets' || isAdmin();
      allow create, update: if isAdmin() && isValidId(settingsId) && 
        (settingsId == 'google_sheets' || isValidSettings(incoming()));
      allow delete: if isAdmin();
    }

    match /contacts/{contactId} {
      allow read, list: if isAdmin();
      allow create: if true; // Anyone can submit contact form
    }
  }
}
